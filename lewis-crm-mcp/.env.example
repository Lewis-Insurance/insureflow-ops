# lewis-crm MCP — secrets live ONLY in this file on the Mac Mini. Never commit, never paste in chat.
# Copy to .env (or merge into ~/.hermes/.env) and fill in.

# Shared Supabase project (the existing "Lewis Insurance App" — do NOT create a new one)
SUPABASE_URL=https://lrqajzwcmdwahnjyidgv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__paste_service_role_key_here__

# Which staff member this agent instance acts as — ONE per Hermes profile.
# The adapter resolves this to a profiles row and refuses to run unless is_staff = true.
LEWIS_PROFILE=brian
LEWIS_EMPLOYEE_EMAIL=brian@lewisinsurance.com

# Private bucket for generated receipts / filled customer docs. NEVER a public bucket.
LEWIS_DOC_BUCKET=customer-docs

# Optional: pin the agency_workspace_id new records are written to.
# Leave blank to use the employee's default_agency_workspace_id.
LEWIS_AGENCY_WORKSPACE_ID=
