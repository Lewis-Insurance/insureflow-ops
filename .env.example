# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Feature Flags
VITE_ENABLE_SIGNUP=false
VITE_REQUIRE_MFA=false
VITE_REQUIRE_PHONE=false
VITE_MIN_PW_LEN=12

# Email Provider (for edge functions)
EMAIL_PROVIDER=postmark
EMAIL_PROVIDER_API_KEY=
INBOUND_PARSE_SECRET=
OUTBOUND_FROM=support@yourdomain.com
OUTBOUND_REPLY_TO=support@yourdomain.com
EMAIL_ALLOW_DEFAULT_DOMAIN=yourdomain.com

# Twilio (for edge functions)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_WEBHOOK_SECRET=