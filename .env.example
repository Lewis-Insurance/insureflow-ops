# =============================================================================
# INSUREFLOW OPS - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.development or .env.production and fill in your values
# Never commit .env files with actual secrets to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# -----------------------------------------------------------------------------
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase Service Role Key (for edge functions only, NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# -----------------------------------------------------------------------------
# Feature Flags (Frontend)
# -----------------------------------------------------------------------------
VITE_ENABLE_SIGNUP=false              # Enable user registration
VITE_REQUIRE_MFA=false                # Require multi-factor authentication
VITE_REQUIRE_PHONE=false              # Require phone verification
VITE_MIN_PW_LEN=12                    # Minimum password length

# Debug and Logging
VITE_DEBUG_MODE=false                 # Enable debug mode
VITE_LOG_LEVEL=error                  # Log level: debug, info, warn, error

# -----------------------------------------------------------------------------
# AI Services (Edge Functions)
# -----------------------------------------------------------------------------

# Lovable AI Gateway (REQUIRED for AI features)
LOVABLE_API_KEY="your-lovable-api-key"

# Google Cloud Vision API (for OCR and document analysis)
GOOGLE_CLOUD_VISION_API_KEY="your-google-vision-key"

# Google Drive API (for document storage)
GOOGLE_DRIVE_API_KEY="your-google-drive-key"
GOOGLE_DRIVE_FOLDER_ID="your-folder-id"

# Azure Document Intelligence (optional, for advanced document analysis)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_DOCUMENT_INTELLIGENCE_KEY="your-azure-key"

# Azure OpenAI (optional, alternative to Lovable)
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_KEY="your-azure-openai-key"
AZURE_OPENAI_DEPLOYMENT_NAME="your-deployment-name"

# -----------------------------------------------------------------------------
# Communication Services (Edge Functions)
# -----------------------------------------------------------------------------

# Email Provider (postmark or sendgrid)
EMAIL_PROVIDER=postmark
EMAIL_PROVIDER_API_KEY="your-email-provider-key"
INBOUND_PARSE_SECRET="your-webhook-secret"
OUTBOUND_FROM=support@yourdomain.com
OUTBOUND_REPLY_TO=support@yourdomain.com
EMAIL_ALLOW_DEFAULT_DOMAIN=yourdomain.com

# Resend (for COI emails)
RESEND_API_KEY="your-resend-key"

# Twilio (for SMS and voice)
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_SMS_WEBHOOK_SECRET="your-webhook-secret"
TWILIO_PHONE_NUMBER="your-twilio-phone"

# -----------------------------------------------------------------------------
# Document Parsing Services (Edge Functions)
# -----------------------------------------------------------------------------

# Parseur (for email parsing)
PARSEUR_API_KEY="your-parseur-key"
PARSEUR_WEBHOOK_API_KEY="your-webhook-key"
PARSEUR_MAILBOX_ID="your-mailbox-id"

# -----------------------------------------------------------------------------
# Coterie Commercial Insurance (Edge Functions) — Phase 1 is MOCK ONLY
# -----------------------------------------------------------------------------
# These are EDGE-FUNCTION secrets only. NEVER prefix with VITE_ / expose to the
# frontend. In Phase 1 the coterie-quote function runs entirely on local
# fixtures: no key is required and NO live Coterie call is made. Leave these
# commented out. They are documented here for a future (non-mock) phase.
#
# COTERIE_PUBLISHABLE_KEY="your-coterie-publishable-key"   # quote creation (token auth)
# COTERIE_SECRET_KEY="your-coterie-secret-key"             # reserved for bind (NOT used in Phase 1)
# COTERIE_AGENCY_EXTERNAL_ID="your-agency-external-id"
# COTERIE_PRODUCER_EXTERNAL_ID="your-producer-external-id"
# COTERIE_API_BASE="https://api-sandbox.coterieinsurance.com/v1.6/commercial"
# COTERIE_SANDBOX_ENABLED=false   # default false -> MOCK mode (fixtures only)
# COTERIE_BIND_ENABLED=false      # MUST stay false in Phase 1 (guards prepareBind/bind)

# -----------------------------------------------------------------------------
# The Floor / Lewis Floor Cockpit (default OFF — Phase 0)
# -----------------------------------------------------------------------------
# Frontend gate for the Lewis Floor cockpit drawer
VITE_LEWIS_FLOOR_COCKPIT_ENABLED=false

# Edge-function gate for hermes-chat, floor-action, Floor writes, and email Floor intake
FLOOR_COCKPIT_ENABLED=false

# Tenant boundary for inbound email Floor intake (dev: Lewis workspace UUID)
# FLOOR_INBOUND_AGENCY_WORKSPACE_ID=your-agency-workspace-uuid

# When true, hermes-chat stays on synthetic SSE even if HERMES_API_URL is set
FLOOR_HERMES_SYNTHETIC=true

# Live Hermes runtime (Mac Mini / lewis-the-floor). Edge-function secrets only.
# HERMES_API_URL=https://hermes.example.com
# HERMES_API_KEY=your-hermes-api-key
# API_SERVER_KEY=your-api-server-key-fallback
# HERMES_MODEL_NAME=hermes-agent

# -----------------------------------------------------------------------------
# Deployment Configuration
# -----------------------------------------------------------------------------

# Node Environment
NODE_ENV=production

# Application URL (for webhooks and callbacks)
APP_URL=https://lewisinsurance.ai

# -----------------------------------------------------------------------------
# Optional Services
# -----------------------------------------------------------------------------

# Analytics (optional)
# VITE_ANALYTICS_ID="your-analytics-id"

# Error Tracking (optional)
# VITE_SENTRY_DSN="your-sentry-dsn"

# Feature Flags Service (optional)
# VITE_FEATURE_FLAGS_KEY="your-feature-flags-key"