# =============================================================================
# VERCEL PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this template and fill in your actual values in Vercel dashboard
# DO NOT commit actual secrets to Git
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Required)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://lrqajzwcmdwahnjyidgv.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# SUPABASE PROJECT (Required for CLI operations)
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_ID=lrqajzwcmdwahnjyidgv
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# -----------------------------------------------------------------------------
# AI SERVICES (Required for AI features)
# -----------------------------------------------------------------------------
# Lovable AI Gateway (if still using)
VITE_LOVABLE_AI_API_KEY=your_lovable_ai_api_key_here

# Google Cloud Vision (for OCR)
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# Azure Document Intelligence (for advanced OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=your_azure_endpoint_here
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_key_here

# -----------------------------------------------------------------------------
# COMMUNICATION SERVICES (Required for SMS/Email)
# -----------------------------------------------------------------------------
# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WEBHOOK_SECRET=your_twilio_webhook_secret_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Email Service (Postmark or SendGrid)
POSTMARK_API_KEY=your_postmark_api_key_here
# OR
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Resend (Email - Deno compatible alternative)
RESEND_API_KEY=your_resend_api_key_here

# -----------------------------------------------------------------------------
# DOCUMENT PARSING (Required for document uploads)
# -----------------------------------------------------------------------------
# Parseur (Document parsing service)
PARSEUR_API_KEY=your_parseur_api_key_here
PARSEUR_WEBHOOK_SECRET=your_parseur_webhook_secret_here

# -----------------------------------------------------------------------------
# INTEGRATIONS (Optional)
# -----------------------------------------------------------------------------
# Google Drive (for document storage)
GOOGLE_DRIVE_CLIENT_ID=your_google_drive_client_id_here
GOOGLE_DRIVE_CLIENT_SECRET=your_google_drive_client_secret_here
GOOGLE_DRIVE_REDIRECT_URI=https://lewisinsurance.ai/oauth/callback

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS (Required)
# -----------------------------------------------------------------------------
NODE_ENV=production
VITE_APP_URL=https://lewisinsurance.ai
VITE_API_URL=https://lrqajzwcmdwahnjyidgv.supabase.co

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_DOCUMENT_ANALYSIS=true
VITE_ENABLE_SMS_NOTIFICATIONS=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=true

# -----------------------------------------------------------------------------
# MONITORING & ANALYTICS (Optional but recommended)
# -----------------------------------------------------------------------------
# Sentry (Error tracking)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Google Analytics
VITE_GA_TRACKING_ID=your_google_analytics_id_here

# -----------------------------------------------------------------------------
# NOTES:
# -----------------------------------------------------------------------------
# 1. Variables prefixed with VITE_ are exposed to the frontend
# 2. Variables without VITE_ are backend-only (Supabase Edge Functions)
# 3. Set these in Vercel Dashboard: Settings → Environment Variables
# 4. Use different values for Preview/Development environments if needed
# =============================================================================
